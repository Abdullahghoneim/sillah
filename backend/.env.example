PORT=3000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sillah?schema=public"

# Better Auth
BETTER_AUTH_SECRET=replace-with-long-random-string-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# SMTP for email OTP delivery
# For local dev, run Mailpit (https://mailpit.axllent.org/) on :1025 or use Gmail SMTP.
# For production, point at your own SMTP server (Postfix, Mailcow, etc).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Sillah <noreply@sillah.local>"
